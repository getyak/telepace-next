# ============================================
# telepace-next — Example env. Copy to .env and fill.
# ============================================
# Pydantic Settings uses prefix TELEPACE_ (interfaces/rest_api/config.py)
# Frontend apps read NEXT_PUBLIC_* via process.env.

# --- Postgres (deploy/docker-compose.dev.yml exposes 15432)
TELEPACE_DATABASE_URL=postgresql://telepace:telepace@localhost:15432/telepace

# --- Redis (deploy/docker-compose.dev.yml exposes 16379)
TELEPACE_REDIS_URL=redis://localhost:16379/0

# --- HTTP server
TELEPACE_API_HOST=0.0.0.0
TELEPACE_API_PORT=8010
TELEPACE_API_VERSION_PREFIX=/v1

# --- Public URLs
TELEPACE_PUBLIC_BASE_URL=http://localhost:3000
TELEPACE_API_BASE_URL=http://localhost:8010

# --- CORS (comma-separated list of allowed origins)
TELEPACE_CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
TELEPACE_CORS_ALLOW_CREDENTIALS=true
TELEPACE_CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
TELEPACE_CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Requested-With

# --- FastAPI docs metadata (shown in /docs)
TELEPACE_API_TITLE=telepace API
TELEPACE_API_VERSION_STRING=0.1.0

# --- Postgres pool
TELEPACE_PG_POOL_MIN_SIZE=1
TELEPACE_PG_POOL_MAX_SIZE=10

# --- Default identity (dev fallback only — real auth overrides these)
TELEPACE_DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001
TELEPACE_DEFAULT_AUTHOR_ID=00000000-0000-0000-0000-000000000002

# --- Auth (JWT)
TELEPACE_AUTH_ENABLED=true
# CRITICAL: replace with a cryptographically random value in production
TELEPACE_JWT_SECRET=dev-insecure-jwt-secret-change-me
TELEPACE_JWT_ALGORITHM=HS256
TELEPACE_JWT_ACCESS_TTL_SECONDS=3600
TELEPACE_JWT_REFRESH_TTL_SECONDS=1209600
TELEPACE_JWT_ISSUER=telepace
TELEPACE_JWT_AUDIENCE=telepace-api

# --- Password policy
TELEPACE_PASSWORD_MIN_LENGTH=8
# PBKDF2-SHA256 iteration count. OWASP-2023 recommends >= 600_000 for prod.
TELEPACE_PASSWORD_PBKDF2_ITERATIONS=600000
TELEPACE_AUTH_MAX_FAILED_ATTEMPTS=5
TELEPACE_AUTH_LOCKOUT_SECONDS=900

# --- Actor prefixes (event log actor namespacing: "<prefix>:<id>")
TELEPACE_ACTOR_PREFIX_USER=user
TELEPACE_ACTOR_PREFIX_SYSTEM=system
TELEPACE_ACTOR_PREFIX_AGENT=agent
TELEPACE_ACTOR_PREFIX_RESPONDENT=respondent
TELEPACE_ACTOR_PREFIX_INTERVIEW=interview

# --- Dev fallback identity (used only when TELEPACE_AUTH_ENABLED=false)
TELEPACE_DEV_FALLBACK_USER_EMAIL=dev@telepace.local

# --- LLM provider: "openrouter" | "anthropic" | "mock"
TELEPACE_LLM_PROVIDER=openrouter

# OpenRouter (OpenAI-compatible protocol)
TELEPACE_OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
TELEPACE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TELEPACE_LLM_MODEL_HEAVY=deepseek/deepseek-v4-pro
TELEPACE_LLM_MODEL_GENERAL=z-ai/glm-4.7
TELEPACE_LLM_MODEL_FAST=deepseek/deepseek-v4-flash

# Anthropic (used only if TELEPACE_LLM_PROVIDER=anthropic)
# TELEPACE_ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
TELEPACE_ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# --- Voice / Telephony / Email (optional)
TELEPACE_VOICE_SERVICE_URL=http://localhost:9099

# --- Dispatch channel providers: each defaults to "mock" (writes JSONL to data/dispatched/)
TELEPACE_EMAIL_PROVIDER=mock
TELEPACE_SMS_PROVIDER=mock
TELEPACE_PHONE_PROVIDER=mock

# Dispatch tuning
TELEPACE_DISPATCH_LOG_DIR=data/dispatched
TELEPACE_CHANNEL_HTTP_TIMEOUT_S=10.0
TELEPACE_DISPATCH_RETRY_ATTEMPTS=3
TELEPACE_DISPATCH_RETRY_BASE_DELAY_S=0.25

# Resend (email) — used when TELEPACE_EMAIL_PROVIDER=resend
# TELEPACE_RESEND_API_KEY=re_REPLACE_ME
TELEPACE_RESEND_BASE_URL=https://api.resend.com
TELEPACE_EMAIL_FROM=telepace <invites@telepace.local>

# Twilio (SMS) — used when TELEPACE_SMS_PROVIDER=twilio
# TELEPACE_TWILIO_ACCOUNT_SID=ACREPLACE_ME
# TELEPACE_TWILIO_AUTH_TOKEN=REPLACE_ME
# TELEPACE_TWILIO_FROM=+15550000000
TELEPACE_TWILIO_BASE_URL=https://api.twilio.com/2010-04-01

# Vapi (outbound phone) — used when TELEPACE_PHONE_PROVIDER=vapi
# TELEPACE_VAPI_API_KEY=REPLACE_ME
# TELEPACE_VAPI_ASSISTANT_ID=REPLACE_ME
# TELEPACE_VAPI_PHONE_NUMBER_ID=REPLACE_ME
TELEPACE_VAPI_BASE_URL=https://api.vapi.ai
TELEPACE_VAPI_CALL_TIMEOUT_S=15.0

# --- Voice pipeline (Phase 3): STT + TTS for /ws/voice/{campaign_id}
# Provider selection: "deepgram" | "mock" and "elevenlabs" | "mock"
TELEPACE_VOICE_STT_PROVIDER=mock
TELEPACE_VOICE_TTS_PROVIDER=mock

# Deepgram STT
# TELEPACE_DEEPGRAM_API_KEY=REPLACE_ME
TELEPACE_DEEPGRAM_WS_URL=wss://api.deepgram.com/v1/listen
TELEPACE_DEEPGRAM_MODEL=nova-3
TELEPACE_DEEPGRAM_LANGUAGE=en-US
TELEPACE_DEEPGRAM_SAMPLE_RATE_HZ=16000
TELEPACE_DEEPGRAM_PING_INTERVAL_S=5
TELEPACE_DEEPGRAM_PING_TIMEOUT_S=20
TELEPACE_DEEPGRAM_ENCODING=opus
TELEPACE_DEEPGRAM_SMART_FORMAT=true
TELEPACE_DEEPGRAM_INTERIM_RESULTS=true

# ElevenLabs TTS
# TELEPACE_ELEVENLABS_API_KEY=REPLACE_ME
TELEPACE_ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
TELEPACE_ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
TELEPACE_ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
TELEPACE_ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
TELEPACE_ELEVENLABS_STABILITY=0.5
TELEPACE_ELEVENLABS_SIMILARITY_BOOST=0.75
TELEPACE_ELEVENLABS_TIMEOUT_S=20.0
TELEPACE_ELEVENLABS_CONNECT_TIMEOUT_S=5.0
TELEPACE_ELEVENLABS_STREAM_CHUNK_BYTES=4096

# --- Object storage (optional)
# TELEPACE_S3_BUCKET=telepace-user-files
# TELEPACE_S3_ENDPOINT=http://localhost:9000

# --- Observability (optional)
# TELEPACE_LANGFUSE_PUBLIC_KEY=
# TELEPACE_LANGFUSE_SECRET_KEY=

# --- Harness / policy tuning
TELEPACE_MEMORY_TTL_SECONDS=3600
TELEPACE_BUDGET_WARN_RATIO=0.8
TELEPACE_BUDGET_HARD_STOP_RATIO=1.0
TELEPACE_EVENT_STORE_MAINTENANCE_INTERVAL_S=3600

# --- Agent LLM tuning (max_tokens / temperature per agent role)
TELEPACE_DESIGNER_MAX_TOKENS=1500
TELEPACE_DESIGNER_TEMPERATURE=0.3
TELEPACE_INTERVIEWER_MAX_TOKENS=800
TELEPACE_INTERVIEWER_TEMPERATURE=0.5
TELEPACE_ANALYST_MAX_TOKENS=3000
TELEPACE_ANALYST_TEMPERATURE=0.3
