# Secrets — never commit
.env
.env.local
.env.*.local
frontend/apps/*/.env.local

# Python
__pycache__/
*.pyc
*.pyo
.venv/
.ruff_cache/
.mypy_cache/
.pytest_cache/
htmlcov/
.coverage
dist/
build/
*.egg-info/

# Node / Next
node_modules/
.next/
out/
.turbo/
.pnpm-store/
frontend/**/tsconfig.tsbuildinfo

# IDE / OS
.DS_Store
.idea/
.vscode/
*.log

# Data
data/
*.duckdb

# Playwright MCP debug artifacts
.playwright-mcp/

# Playwright E2E
# .auth holds a real signed-in session cookie — never commit it.
frontend/e2e/.auth/
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
frontend/.cache/
